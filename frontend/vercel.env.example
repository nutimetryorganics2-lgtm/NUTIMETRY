# Vercel Production Environment Variables
# Create these in Vercel Dashboard -> Settings -> Environment Variables

# Backend API Base URL (Render/AWS URL)
VITE_API_BASE_URL=https://nutimetryorganic-backend.onrender.com/api

# Environment (production / development)
VITE_ENV=production

# Sentry Frontend DSN
VITE_SENTRY_DSN=https://your_sentry_dsn@o000000.ingest.sentry.io/0000000
