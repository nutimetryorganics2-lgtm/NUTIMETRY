# --- BACKEND .env.example ---
ENVIRONMENT=production
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/nutrimetry_db?retryWrites=true&w=majority
SECRET_KEY=your_very_secret_key_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD="your_app_password"
NOTIFICATION_EMAIL=target_admin_email@gmail.com
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
FRONTEND_URL=https://nutrimerty-spirulina.vercel.app

# --- FRONTEND .env.example ---
VITE_API_BASE_URL=https://nutrimerty-spirulina-backend.onrender.com/api
VITE_ENVIRONMENT=production
VITE_SENTRY_DSN=your_sentry_dsn_here
