# NutrimetryOrganic Production Backend Environment Variables
# NEVER COMMIT THE ACTUAL .env FILE

ENVIRONMENT=production
PROJECT_NAME=NutimetryOrganic Platform

# MongoDB Atlas Connection String
# IMPORTANT: Allowlist Render/AWS IPs or use 0.0.0.0/0
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/nutimetry_organic_db?retryWrites=true&w=majority

# Security
SECRET_KEY=generate_a_very_secure_random_string_here

# URLs for CORS
FRONTEND_URL=https://nutimetryorganic.vercel.app
STAGING_URL=https://staging-nutimetryorganic.vercel.app

# Email Service (SendGrid / SES / SMTP)
SMTP_SERVER=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
NOTIFICATION_EMAIL=BHANUNIDUMOL@GMAIL.COM

# Monitoring
SENTRY_DSN=https://your_sentry_dsn@o000000.ingest.sentry.io/0000000

# Other
CLOUDINARY_URL=
